body {
    margin: 0;
    padding: 0;
    background-color: #0f172a;
    color: white;
    font-family: Arial, sans-serif;
    text-align: center;
}

h1 {
    color: #00d4ff;
    margin-top: 80px;
    font-size: 42px;
}

p {
    font-size: 20px;
    color: #d1d5db;
}

button {
    background-color: #00d4ff;
    color: black;
    border: none;
    padding: 15px 30px;
    font-size: 18px;
    border-radius: 10px;
    cursor: pointer;
}

button:hover {
    background-color: #0099cc;
}
